# Copy this file to .env and fill in the values.

# ── Required to start the server ───────────────────────────────────────────

# Postgres connection string — use postgresql+psycopg:// (psycopg v3 driver)
ZER0_DATABASE_URL=postgresql+psycopg://zer0:zer0@localhost:5432/zer0

# Google Gemini API key — used for all LLM calls (discovery, research, drafting)
# Get one at https://aistudio.google.com/app/apikey
ZER0_GEMINI_API_KEY=

# ── Required to run campaigns ────────────────────────────────────────────────

# Tavily search API key — used by the discovery node to find leads
# Get one at https://app.tavily.com
ZER0_TAVILY_API_KEY=

# Fernet encryption key — used to encrypt/decrypt per-tenant email & WhatsApp credentials stored in the DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ZER0_CREDENTIAL_ENCRYPTION_KEY=

# ── Optional — defaults shown ────────────────────────────────────────────────

# LLM settings
ZER0_LLM_PROVIDER=gemini
ZER0_LLM_MODEL=gemini-2.0-flash
ZER0_LLM_MAX_TOKENS=4096

# Logging
ZER0_LOG_LEVEL=INFO
ZER0_DEBUG=false

# CORS — comma-separated origins allowed to call the API from a browser
# Required when running the Next.js dev server (npm run dev) alongside the API.
# Leave empty in production — the static UI is served same-origin by the API.
ZER0_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
